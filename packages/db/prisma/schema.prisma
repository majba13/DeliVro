generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  SHOP_OWNER
  DELIVERY_MAN
  CUSTOMER
}

enum ProductCategory {
  FOOD
  GROCERIES
  STATIONARY
  MEDICINE
  WEAR
  ELECTRONICS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  BKASH
  NAGAD
  ROCKET
  BANK
  COD
}

enum PaymentStatus {
  INITIATED
  PENDING_VERIFICATION
  VERIFIED
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  ON_THE_WAY
  DELIVERED
}

model User {
  id               String      @id @default(cuid()) @map("_id")
  name             String?
  email            String?     @unique
  phone            String?     @unique
  passwordHash     String?
  googleId         String?     @unique
  isVerified       Boolean     @default(false)
  role             RoleType
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  adminPermissions AdminPermission[]
  products         Product[]
  customerOrders   Order[]     @relation("CustomerOrders")
  ownerOrders      Order[]     @relation("OwnerOrders")
  deliveries       Delivery[]
  payments         Payment[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  cartItems        CartItem[]
  locationPings    DeliveryLocation[] @relation("DeliveryManLocations")
}

model AdminPermission {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  key         String
  canRead     Boolean  @default(false)
  canWrite    Boolean  @default(false)
  canDelete   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([key])
}

model Product {
  id          String          @id @default(cuid()) @map("_id")
  ownerId     String
  name        String
  description String
  category    ProductCategory
  price       Float
  images      String[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  inventory Inventory?
  items     OrderItem[]
  cartItems CartItem[]

  @@index([ownerId])
  @@index([category])
}

model Inventory {
  id          String   @id @default(cuid()) @map("_id")
  productId   String   @unique
  stock       Int
  reserved    Int      @default(0)
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  productId String
  quantity  Int      @default(1)
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id               String      @id @default(cuid()) @map("_id")
  customerId       String
  ownerId          String
  status           OrderStatus @default(PENDING)
  subtotal         Float
  deliveryFee      Float
  total            Float
  deliveryAddress  Json?
  estimatedMinutes Int?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  customer User @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: NoAction)
  owner    User @relation("OwnerOrders", fields: [ownerId], references: [id], onDelete: NoAction)

  items     OrderItem[]
  payment   Payment?
  delivery  Delivery?
  locationPings DeliveryLocation[]

  @@index([customerId])
  @@index([ownerId])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid()) @map("_id")
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: NoAction)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                 String        @id @default(cuid()) @map("_id")
  orderId            String        @unique
  userId             String
  method             PaymentMethod
  status             PaymentStatus @default(INITIATED)
  amount             Float
  transactionId      String?
  stripePaymentId    String?
  mobileReference    String?
  verificationLog    Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: NoAction)

  @@index([method])
  @@index([status])
}

model Delivery {
  id                String         @id @default(cuid()) @map("_id")
  orderId           String         @unique
  deliveryManId     String
  status            DeliveryStatus @default(ASSIGNED)
  currentLat        Float?
  currentLng        Float?
  etaMinutes        Int?
  lastTrackedAt     DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryMan User  @relation(fields: [deliveryManId], references: [id], onDelete: NoAction)

  @@index([deliveryManId])
  @@index([status])
}

model Notification {
  id          String   @id @default(cuid()) @map("_id")
  userId      String
  title       String
  message     String
  isRead      Boolean  @default(false)
  channel     String
  payload     Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model AuditLog {
  id          String   @id @default(cuid()) @map("_id")
  userId      String?
  action      String
  resource    String
  resourceId  String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Real-time delivery GPS breadcrumb trail ───────────────────────────────
model DeliveryLocation {
  id            String   @id @default(cuid()) @map("_id")
  deliveryManId String
  orderId       String?
  latitude      Float
  longitude     Float
  speed         Float?   // km/h — optional
  heading       Float?   // degrees 0-359 — optional
  accuracy      Float?   // metres — optional
  recordedAt    DateTime @default(now())

  deliveryMan User     @relation("DeliveryManLocations", fields: [deliveryManId], references: [id], onDelete: Cascade)
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([deliveryManId])
  @@index([orderId])
  @@index([recordedAt])
}
